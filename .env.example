# Copy to .env and fill in. Without keys the system runs in deterministic OFFLINE mock mode.

# --- LLM (OpenRouter, OpenAI-compatible) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Model used by complex agents (router/advisor/synthesizer & baseline)
MODEL_SMART=anthropic/claude-3.5-sonnet
# Cheaper model for simple roles (data analyst tool-runner)
MODEL_CHEAP=anthropic/claude-3.5-haiku

# Force offline mock even if a key is present (1/0)
FINANCE_COACH_OFFLINE=0

# --- LangSmith (observability + experiments) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=personal-finance-coach
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Reference "today" for relative dates (dataset ends 2025-11-30)
FINANCE_COACH_NOW=2025-11-30
